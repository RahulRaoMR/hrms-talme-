DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"
# Optional: direct/non-pooled database URL for Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"
# On deployed frontend, point API calls to the persistent backend service.
# Do not use MONGODB_URI for this app; persistence is Prisma + PostgreSQL.
API_BASE_URL="https://talme-hrms-backend.onrender.com"
NEXT_PUBLIC_API_URL="https://talme-hrms-backend.onrender.com"
