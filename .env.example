DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
# On deployed frontend, point API calls to the persistent backend service.
# Do not use MONGODB_URI for this app; persistence is Prisma + PostgreSQL.
API_BASE_URL=
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"

# Email delivery for employee welcome/password emails.
# Use "resend", "smtp", or "gmail"; if omitted, RESEND_API_KEY + EMAIL_FROM uses Resend.
EMAIL_PROVIDER=""
EMAIL_SERVICE="gmail"
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="Talme HRMS <no-reply@example.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
RESEND_API_KEY=""

# Optional ATS SharePoint workbook sync.
ATS_SHAREPOINT_SYNC_ENABLED="false"
MICROSOFT_TENANT_ID=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
ATS_SHAREPOINT_WORKBOOK_URL=""
# Optional alternative to ATS_SHAREPOINT_WORKBOOK_URL.
ATS_SHAREPOINT_DRIVE_ID=""
ATS_SHAREPOINT_ITEM_ID=""
ATS_SHAREPOINT_REQUIREMENTS_SHEET="Requirement Overview"
ATS_SHAREPOINT_CANDIDATES_SHEET="Candidate Master"
ATS_SHAREPOINT_IMPORT_INTERVAL_MS="60000"
